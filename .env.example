# ── LLM (Ollama) ──────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:8b

# ── Langfuse (copy from http://localhost:3000 after first login) ──
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ── Langfuse Docker stack (docker-compose.yml) ────────────────────
# Defaults are fine for local dev; change before any public exposure.
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse
POSTGRES_DB=langfuse
LANGFUSE_NEXTAUTH_SECRET=change-me-langfuse-secret
LANGFUSE_SALT=change-me-langfuse-salt

# ── Chainlit ──────────────────────────────────────────────────────
CHAINLIT_AUTH_SECRET=change-me-chainlit-secret

# ── LandingAI (Stage 1 ingestion only) ───────────────────────────
VISION_AGENT_API_KEY=
